classDiagram
    %% PawPal+ system design — working draft (revisit in Phase 6 to match implementation).

    class Owner {
        +str name
        +int daily_minutes_available
        +dict preferences
        +add_pet(pet) None
        +set_preferences(prefs) None
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +add_task(task) None
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +bool recurring
        +priority_rank() int
    }

    class Scheduler {
        +list~Task~ tasks
        +int available_minutes
        +add_task(task) None
        +generate_plan() list
        +explain_plan() str
    }

    Owner "1" --> "*" Pet : owns
    Pet "1" --> "*" Task : has
    Scheduler "1" --> "*" Task : schedules
